{
  "name": "the-jazz-graph",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "fetch-data": "node scripts/fetch-data.mjs",
    "fetch-spotify-covers": "node scripts/fetch-spotify-covers.mjs",
    "fetch-covers": "node scripts/fetch-covers.mjs",
    "fetch-tracks": "node scripts/fetch-tracks.mjs",
    "extract-colors": "node scripts/extract-colors.mjs",
    "fix-labels": "node scripts/fix-labels.mjs",
    "fix-labels-discogs": "node scripts/fix-labels-discogs.mjs --prune",
    "fix-missing-labels": "node scripts/fix-missing-labels.mjs --prune",
    "optimize-images": "node scripts/optimize-images.mjs",
    "pipeline": "npm run fetch-data && npm run fetch-spotify-covers && npm run fetch-covers && npm run extract-colors && npm run fix-labels && npm run fix-missing-labels && npm run fix-labels-discogs && npm run optimize-images"
  },
  "dependencies": {
    "culori": "^4.0.2",
    "d3": "^7.9.0",
    "node-vibrant": "^4.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "sharp": "^0.34.5",
    "vite": "^6.0.0"
  }
}
